generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TableStatus {
  OPEN
  CLOSED
}

enum PlayerStatus {
  ACTIVE
  CASHOUT
}

enum TxType {
  BUY_IN
  REBUY
  CASH_OUT
  ADJUSTMENT
}

enum PendingPlayerActionType {
  REBUY
  CASH_OUT
}

enum PendingPlayerActionStatus {
  PENDING
  APPROVED
  DENIED
}

model User {
  id           String  @id @default(uuid()) @db.Uuid
  email        String  @unique
  passwordHash String
  createdAt    DateTime @default(now())

  tables       Table[]
  tablePlayers TablePlayer[]
  requestedPlayerActions PendingPlayerAction[] @relation("RequestedPlayerActions")
  approverPlayerActions  PendingPlayerAction[] @relation("ApproverPlayerActions")
  decidedPlayerActions   PendingPlayerAction[] @relation("DecidedPlayerActions")
}

model Table {
  id                         String       @id @default(uuid()) @db.Uuid
  ownerUserId                String       @db.Uuid
  name                       String
  code                       String       @unique
  inviteToken                String       @unique
  accessPasswordHash         String
  blinds                     String
  currency                   String
  status                     TableStatus  @default(OPEN)
  createdAt                  DateTime     @default(now())
  closedAt                   DateTime?
  valorFichaCents            Int          @default(100)
  buyInMinimoCents           Int          @default(5000)
  buyInMaximoCents           Int?
  permitirRebuy              Boolean      @default(true)
  limiteRebuys               Int          @default(0)
  totalMesaCents             Int          @default(0)
  ajusteProporcionalAplicado Boolean      @default(false)

  owner       User         @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  players     TablePlayer[]
  transactions Transaction[]
  rankings    Ranking[]
  pendingPlayerActions PendingPlayerAction[]

  @@index([ownerUserId])
}

model TablePlayer {
  id                String       @id @default(uuid()) @db.Uuid
  tableId           String       @db.Uuid
  userId            String       @db.Uuid
  name              String
  status            PlayerStatus @default(ACTIVE)
  createdAt         DateTime     @default(now())
  buyInInicialCents Int
  totalInvestidoCents Int
  valorFinalCents   Int?
  resultadoCents    Int?
  cashoutAt         DateTime?

  table        Table          @relation(fields: [tableId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  transactions Transaction[]
  pendingActions PendingPlayerAction[]

  @@index([tableId])
  @@index([userId])
  @@unique([tableId, userId])
}

model PendingPlayerAction {
  id              String                    @id @default(uuid()) @db.Uuid
  tableId         String                    @db.Uuid
  tablePlayerId   String                    @db.Uuid
  requesterUserId String                    @db.Uuid
  approverUserId  String                    @db.Uuid
  decidedByUserId String?                   @db.Uuid
  type            PendingPlayerActionType
  amountCents     Int
  status          PendingPlayerActionStatus @default(PENDING)
  createdAt       DateTime                  @default(now())
  decidedAt       DateTime?

  table      Table       @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tablePlayer TablePlayer @relation(fields: [tablePlayerId], references: [id], onDelete: Cascade)
  requester  User        @relation("RequestedPlayerActions", fields: [requesterUserId], references: [id], onDelete: Cascade)
  approver   User        @relation("ApproverPlayerActions", fields: [approverUserId], references: [id], onDelete: Cascade)
  decidedBy  User?       @relation("DecidedPlayerActions", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([tableId])
  @@index([approverUserId, status])
  @@index([tablePlayerId, type, status])
}

model Transaction {
  id            String   @id @default(uuid()) @db.Uuid
  tableId       String   @db.Uuid
  tablePlayerId String   @db.Uuid
  type          TxType
  amountCents   Int
  createdAt     DateTime @default(now())
  note          String?

  table       Table       @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tablePlayer TablePlayer @relation(fields: [tablePlayerId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@index([tablePlayerId])
}

model Ranking {
  id              String   @id @default(uuid()) @db.Uuid
  ownerUserId     String   @db.Uuid
  tableId         String   @db.Uuid
  playerName      String
  totalLucroCents Int      @default(0)
  partidasJogadas Int      @default(0)
  partidasGanhas  Int      @default(0)
  partidasPerdidas Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
  @@index([tableId])
  @@unique([ownerUserId, playerName])
}
